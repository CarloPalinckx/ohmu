{
  "name": "@ohm/coding-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "start": "tsx src/scripts/run-mission.ts work-on-github-project",
    "mission": "tsx src/scripts/run-mission.ts",
    "generate-templates": "tsx src/scripts/generate-templates.ts",
    "dashboard": "cd ui && npm run dev",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix",
      "bash -c 'tsc --noEmit'",
      "bash -c 'vitest run --coverage'"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "tsx": "^4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "typescript": "5.8",
    "vitest": "^4.1.6"
  }
}
